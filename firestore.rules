rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isActiveMember() {
      return isAuth() &&
        exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status == 'active';
    }

    // ─── Members Collection ──────────────────────────────────────────

    match /members/{uid} {
      // Any authenticated active member can read other active members
      allow read: if isOwner(uid) || (isActiveMember() && resource.data.status == 'active') || isAdmin();

      // Only the member themselves can create their own document (on registration)
      allow create: if isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.status == 'pending_payment';

      // Member can update their own profile (excluding status/isVerified)
      allow update: if isOwner(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isVerified', 'uid', 'joinedAt']) ||
        isAdmin();

      allow delete: if isAdmin();
    }

    // ─── Payments Collection ─────────────────────────────────────────

    match /payments/{paymentId} {
      // Members can read their own payments
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());

      // Members can create payment submissions for themselves
      allow create: if isAuth() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'submitted';

      // Only admin can update payment status
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ─── App Config ──────────────────────────────────────────────────

    match /app_config/{docId} {
      // Any authenticated user can read config (needed for payment amounts)
      allow read: if isAuth();
      // Only admin can write config
      allow write: if isAdmin();
    }
  }
}