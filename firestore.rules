rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Safe version: won't throw if member doc doesn't exist yet
    function isActiveMember() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status == 'active';
    }

    // ── Members Collection ────────────────────────────────────────────
    match /members/{uid} {

      // Create: user creates their own doc during registration
      // status must start as pending_approval, isVerified must be false
      allow create: if isOwner(uid)
                    && request.resource.data.status == 'pending_approval'
                    && request.resource.data.isVerified == false;

      // Read:
      // - Admin reads all
      // - Owner reads their own (any status)
      // - Active members can read other active members
      allow read: if isAdmin()
                  || isOwner(uid)
                  || (isActiveMember() && resource.data.status == 'active');

      // Update:
      // - Admin can update anything
      // - Owner can update profile fields but cannot change status/isVerified/regNumber
      allow update: if isAdmin()
                    || (
                      isOwner(uid)
                      && request.resource.data.status == resource.data.status
                      && request.resource.data.isVerified == resource.data.isVerified
                      && request.resource.data.regNumber == resource.data.regNumber
                    );

      allow delete: if isAdmin();
    }

    // ── Payments Collection ───────────────────────────────────────────
    match /payments/{paymentId} {

      // Create: owner submits their own payment, status must be 'submitted'
      allow create: if isAuthenticated()
                    && isOwner(request.resource.data.uid)
                    && request.resource.data.status == 'submitted';

      // Read: admin reads all, owner reads their own
      // Use request.auth.uid comparison to avoid crashes on list queries
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.uid == request.auth.uid);

      // Update/Delete: admin only
      allow update, delete: if isAdmin();
    }

    // ── App Configuration ─────────────────────────────────────────────
    match /config/app {
      // Anyone can read config — needed on registration page before auth
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Deletion Requests ─────────────────────────────────────────────
    match /deletion_requests/{uid} {
      allow create: if isOwner(uid);
      allow read, update, delete: if isAdmin();
    }
  }
}
